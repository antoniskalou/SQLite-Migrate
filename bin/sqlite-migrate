#!/usr/bin/env perl
use v5.26;
use strict;
use warnings;

use SQLite::Migrate::CLI qw();

exit SQLite::Migrate::CLI::run(@ARGV);

__END__

=head1 NAME

  sqlite-migrate - Manage database migrations

=head1 SYNOPSIS

  sqlite-migrate <command> <db_path> [options]

  sqlite-migrate deploy <db_path>
  sqlite-migrate rollback <db_path> [version]

=head1 OPTIONS

=head2 --dir <path>

A directory containing migration files (defaults to ./sql).

=head1 COMMANDS

=over 4

=item B<deploy>

Apply all pending migrations.

=item B<rollback> [version]

Rollback migrations.

If C<version> is provided, the database will be rolled back to that specific
version. Otherwise all migrations are reverted.

=back

=head1 EXAMPLES

  sqlite-migrate deploy data/my.db
  sqlite-migrate rollback data/my.db 2
  sqlite-migrate rollback data/my.db

=cut
